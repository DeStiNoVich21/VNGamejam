--- !u!114 &190874722
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 190874717}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9112519fb58adc642b88d42836847496, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  characters:
  - portait: {fileID: -5009796695780402884, guid: d1632514ea65d82459e6c02b7af5cca8, type: 3}
    name: "\u041A\u0430\u0439\u0440\u043D"
    text: "\u041A\u0430\u0439\u0440\u043D (\u0421\u0442\u0430\u0440\u0448\u0438\u0439
      \u043C\u0435\u0445\u0430\u043D\u0438\u043A): \u041E\u043B\u0438\u0446\u0435\u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0435
      \u0432\u043E\u043B\u044C\u043D\u043E\u0433\u043E \u0444\u043B\u043E\u0442\u0430
      \u0434\u0440\u0435\u0432\u043D\u043E\u0441\u0442\u0438; \u0437\u0430\u043C\u0435\u043D\u0438\u043B
      \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u044B
      \u043A\u043E\u0441\u0442\u0435\u0439 \u043D\u043E\u0433 \u0438\u043C\u043F\u043B\u0430\u043D\u0442\u0430\u043C\u0438,
      \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0442\u044C
      \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u0437\u043E\u043D\u0430\u0445
      \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u0438."
    characteristic:
      technique: 10
      endurance: 9
      mentalStrength: 4
      perception: 2
  - portait: {fileID: 2256532143125123215, guid: 71d5df607c6f94342a374307050bc18f, type: 3}
    name: "\u041B\u044E\u0432\u0435\u043D"
    text: "\u041B\u044E\u0432\u0435\u043D (\u041C\u0435\u0445\u0430\u043D\u0438\u043A-\u0441\u0442\u0430\u0436\u0435\u0440):
      \u0421\u0438\u0440\u043E\u0442\u0430 \u0441 \u043F\u0440\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u043E\u0439
      \u043A\u043E\u043B\u043E\u043D\u0438\u0438, \u0432\u0437\u044F\u0442\u044B\u0439
      \u041A\u0430\u0439\u0440\u043D\u043E\u043C \u043F\u043E\u0434 \u043B\u0438\u0447\u043D\u0443\u044E
      \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C;
      \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u0432\u044B\u0441\u043E\u043A\u0438\u0435
      \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0432 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u043E\u0439
      \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0438\u0438 \u043F\u0440\u0438 \u043A\u0440\u0430\u0439\u043D\u0435
      \u043D\u0438\u0437\u043A\u043E\u043C \u043F\u043E\u0440\u043E\u0433\u0435 \u0441\u0442\u0440\u0435\u0441\u0441\u043E\u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438."
    characteristic:
      technique: 9
      endurance: 5
      mentalStrength: 3
      perception: 8
  - portait: {fileID: -5293239453282161880, guid: 1597ca34de0fa70479d98750cee199f3, type: 3}
    name: "\u0421\u0442\u0435\u043B\u043B\u0430"
    text: "\u0421\u0442\u0435\u043B\u043B\u0430 (\u041D\u0430\u0432\u0438\u0433\u0430\u0442\u043E\u0440):
      \u0412\u044B\u043F\u0443\u0441\u043A\u043D\u0438\u0446\u0430 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
      \u0441 \u043E\u0442\u043B\u0438\u0447\u0438\u0435\u043C \u043F\u043E \u043A\u0443\u0440\u0441\u0443
      \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0433\u043E \u043A\u043E\u0441\u043C\u043E\u0441\u0430;
      \u0441\u043A\u043B\u043E\u043D\u043D\u0430 \u043A \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u0432\u043D\u044B\u043C
      \u044D\u043F\u0438\u0437\u043E\u0434\u0430\u043C, \u043D\u043E \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
      \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u043E\u0439
      \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0435\u0439 \u0432 \u043F\u0440\u043E\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u043D\u0438\u0438
      \u043A\u0443\u0440\u0441\u043E\u0432."
    characteristic:
      technique: 7
      endurance: 3
      mentalStrength: 6
      perception: 9
  - portait: {fileID: 6450629617884470173, guid: c267109fa9624ac44a2194e24ac7f613, type: 3}
    name: "\u042D\u043A\u043B\u0435\u0441\u0441"
    text: "\u042D\u043A\u043B\u0435\u0441\u0441 (\u041A\u0432\u0430\u0440\u0442\u0435\u0440\u043C\u0435\u0439\u0441\u0442\u0435\u0440):
      \u0411\u044B\u0432\u0448\u0438\u0439 \u043E\u0444\u0438\u0446\u0435\u0440 \u0441\u043D\u0430\u0431\u0436\u0435\u043D\u0438\u044F
      \u043F\u043E\u0433\u0440\u0430\u043D\u0438\u0447\u043D\u043E\u0433\u043E \u0444\u043B\u043E\u0442\u0430;
      \u043E\u0442\u043B\u0438\u0447\u0430\u0435\u0442\u0441\u044F \u0436\u0435\u0441\u0442\u043A\u0438\u043C
      \u0441\u0442\u0438\u043B\u0435\u043C \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u0430
      \u0440\u0435\u0441\u0443\u0440\u0441\u0430\u043C\u0438 \u0438 \u043F\u0430\u0442\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C
      \u043D\u0435\u0434\u043E\u0432\u0435\u0440\u0438\u0435\u043C \u043A \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u0438\u043C
      \u043B\u0438\u0446\u0430\u043C."
    characteristic:
      technique: 5
      endurance: 8
      mentalStrength: 5
      perception: 7
  - portait: {fileID: 1647301221758913653, guid: e89bc2e2c514bc64d93b4d9aec8b3dd7, type: 3}
    name: "\u0412\u0430\u0440\u0433"
    text: "\u0412\u0430\u0440\u0433 (\u0417\u0430\u0432\u0441\u043A\u043B\u0430\u0434):
      \u0412\u0435\u0442\u0435\u0440\u0430\u043D \u0448\u0442\u0443\u0440\u043C\u043E\u0432\u044B\u0445
      \u043F\u043E\u0434\u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u0438\u0439
      \u0441 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
      \u043A\u043E\u043D\u0442\u0443\u0437\u0438\u044F\u043C\u0438, \u0432\u044B\u0441\u043E\u043A\u0430\u044F
      \u0438\u0441\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
      \u0438 \u0445\u043E\u0440\u043E\u0448\u0438\u0439 \u043F\u043E\u0441\u043B\u0443\u0436\u043D\u043E\u0439
      \u0441\u043F\u0438\u0441\u043E\u043A"
    characteristic:
      technique: 3
      endurance: 10
      mentalStrength: 2
      perception: 10
  - portait: {fileID: -7477430044743642851, guid: 0c292fdcd3063374c984b54617b1a7d9, type: 3}
    name: "\u041A\u043B\u0435\u043C\u0435\u043D\u0442\u0438\u043D\u0430"
    text: "\u041A\u043B\u0435\u043C\u0435\u043D\u0442\u0438\u043D\u0430 (\u041C\u0435\u0434\u0438\u043A):
      \u0421\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442 \u043F\u043E \u044D\u043A\u0437\u043E\u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438
      \u0438 \u043F\u043E\u043B\u0435\u0432\u043E\u0439 \u0445\u0438\u0440\u0443\u0440\u0433\u0438\u0438;
      \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043D\u0430 \u043D\u0430 \u0431\u043E\u0440\u0442
      \u043F\u043E \u0441\u0432\u043E\u0435\u0439 \u0438\u043D\u0438\u0446\u0438\u0430\u0442\u0438\u0432\u0435.
      \u041F\u0440\u0438\u0447\u0438\u043D\u044B \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B
      \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u043A\u0430\u0441\u0430\u044E\u0442\u0441\u044F
      \u043B\u0438\u0447\u043D\u043E\u0433\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0430"
    characteristic:
      technique: 6
      endurance: 4
      mentalStrength: 8
      perception: 7
  characterPrefab: {fileID: 6649847372224799784, guid: a16eb0124f3c06a45ad018e57881c973, type: 3}
  spawned: []
